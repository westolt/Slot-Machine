{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "rootDir": "..",
    "outDir": "./build",

    "strict": true,
    "esModuleInterop": true,

    "types": ["node"],

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "../shared"]
}